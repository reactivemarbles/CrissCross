<UserControl
    x:Class="CrissCross.Avalonia.UI.Gallery.Views.Pages.InputPageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CrissCross.Avalonia.UI.Controls"
    xmlns:vm="using:CrissCross.Avalonia.UI.Gallery.ViewModels"
    x:DataType="vm:InputPageViewModel">

    <ScrollViewer>
        <controls:StackPanel Margin="24" Spacing="16">
            <controls:TextBlock
                FontSize="32"
                FontWeight="Bold"
                Text="Input Controls" />

            <controls:TextBlock
                Opacity="0.7"
                Text="Input controls allow users to enter and edit data. CrissCross provides enhanced input controls with validation, formatting, and rich styling."
                TextWrapping="Wrap" />

            <!--  TextBox  -->
            <controls:Card Margin="0,16,0,0">
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="TextBox" />
                    <controls:TextBlock Opacity="0.7" Text="Text boxes allow users to enter text." />
                    <controls:StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Standard TextBox:" />
                            <controls:TextBox PlaceholderText="Enter text here..." />
                        </controls:StackPanel>
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Disabled TextBox:" />
                            <controls:TextBox IsEnabled="False" PlaceholderText="Disabled" />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  AutoSuggestBox  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="AutoSuggestBox" />
                    <controls:TextBlock Opacity="0.7" Text="AutoSuggestBox provides suggestions as users type. Start typing a fruit name to see suggestions." />
                    <controls:StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Search for fruits:" />
                            <controls:AutoSuggestBox
                                FilterMode="Contains"
                                ItemsSource="{Binding SampleSuggestions}"
                                MinimumPrefixLength="1"
                                PlaceholderText="Type to search fruits..." />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  RichTextBox  -->
            <controls:Card>
                <controls:StackPanel Spacing="14">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="RichTextBox" />
                    <controls:TextBlock
                        Opacity="0.7"
                        Text="RichTextBox demonstrates formatted editing, rich clipboard, drag/drop, document serialization, and display-only review modes."
                        TextWrapping="Wrap" />

                    <controls:TextBlock
                        Margin="16,0,0,0"
                        FontSize="12"
                        Opacity="0.7">
                        <Run FontWeight="Bold" Text="Formatting toolbar and commands: " /><Run Text="select text, then use buttons or Ctrl+B/Ctrl+I/Ctrl+U for inline styles, font family, size, foreground, and highlight." />
                        <LineBreak />
                        <Run FontWeight="Bold" Text="Context menu: " /><Run Text="right-click inside the editor for undo, redo, cut, copy, paste, select all, and formatting actions with live enabled state." />
                        <LineBreak />
                        <Run FontWeight="Bold" Text="Drag and drop text or images: " /><Run Text="drop plain text, HTML fragments, image files, or data:image URIs when drag/drop and image-drop are enabled." />
                        <LineBreak />
                        <Run FontWeight="Bold" Text="Copy/paste workflow: " /><Run Text="copy or cut selected formatted text, paste rich/plain clipboard samples, and paste image clipboard samples." />
                        <LineBreak />
                        <Run FontWeight="Bold" Text="Serialization/import/export samples: " /><Run Text="load plain text, HTML, Markdown, save/load streams, and export HTML/Markdown snapshots." />
                        <LineBreak />
                        <Run FontWeight="Bold" Text="Edit/display mode switch: " /><Run Text="toggle the main editor between EditOnFocus and Display while the preview stays in EditMode=&quot;Display&quot;." />
                    </controls:TextBlock>

                    <controls:StackPanel HorizontalAlignment="Left" Spacing="16">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Representative editor surface:" />
                            <controls:RichTextBox
                                Name="FormattingRichTextBox"
                                Width="760"
                                MinHeight="220"
                                AcceptsReturn="True"
                                AcceptsTab="True"
                                EditMode="EditOnFocus"
                                IsDocumentEnabled="True"
                                IsDragDropEnabled="True"
                                IsFormattingEnabled="True"
                                IsImageDropEnabled="True"
                                IsImagePasteEnabled="True"
                                IsRichClipboardEnabled="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Watermark="Type formatted content, paste text/images, or drop content here." />
                        </controls:StackPanel>

                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Display-only preview (EditMode=&quot;Display&quot;):" />
                            <controls:RichTextBox
                                Name="DisplayRichTextBox"
                                Width="760"
                                MinHeight="120"
                                EditMode="Display"
                                IsReadOnly="True"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto" />
                        </controls:StackPanel>

                        <controls:StackPanel Spacing="8">
                            <controls:TextBlock
                                FontSize="12"
                                Opacity="0.7"
                                Text="Formatting toolbar and commands:" />
                            <WrapPanel ItemHeight="32" ItemWidth="150" Orientation="Horizontal">
                                <controls:Button Click="OnRichTextSelectAllClick" Content="Select All" />
                                <controls:Button Click="OnRichTextBoldClick" Content="Toggle Bold" />
                                <controls:Button Click="OnRichTextItalicClick" Content="Toggle Italic" />
                                <controls:Button Click="OnRichTextUnderlineClick" Content="Toggle Underline" />
                                <controls:Button Click="OnRichTextStrikeClick" Content="Toggle Strikethrough" />
                                <controls:Button Click="OnRichTextClearFormattingClick" Content="Clear Formatting" />
                                <controls:Button Click="OnRichTextFontFamilyClick" Content="Font Family" />
                                <controls:Button Click="OnRichTextFontSizeClick" Content="Font Size" />
                                <controls:Button Click="OnRichTextForegroundClick" Content="Foreground" />
                                <controls:Button Click="OnRichTextHighlightClick" Content="Highlight" />
                                <controls:Button Click="OnRichTextUndoClick" Content="Undo" />
                                <controls:Button Click="OnRichTextRedoClick" Content="Redo" />
                            </WrapPanel>
                        </controls:StackPanel>

                        <controls:StackPanel Spacing="8">
                            <controls:TextBlock
                                FontSize="12"
                                Opacity="0.7"
                                Text="Clipboard, context menu, and drag/drop workflows:" />
                            <WrapPanel ItemHeight="32" ItemWidth="170" Orientation="Horizontal">
                                <controls:Button Click="OnRichTextCopyClick" Content="Copy Selection" />
                                <controls:Button Click="OnRichTextCutClick" Content="Cut Selection" />
                                <controls:Button Click="OnRichTextPasteSampleClick" Content="Paste Clipboard Sample" />
                                <controls:Button Click="OnRichTextPasteImageSampleClick" Content="Paste Image Sample" />
                                <controls:Button Click="OnRichTextDropTextSampleClick" Content="Drop Text Sample" />
                                <controls:Button Click="OnRichTextDropImageSampleClick" Content="Drop Image Sample" />
                            </WrapPanel>
                        </controls:StackPanel>

                        <controls:StackPanel Spacing="8">
                            <controls:TextBlock
                                FontSize="12"
                                Opacity="0.7"
                                Text="Serialization/import/export samples and mode switching:" />
                            <WrapPanel ItemHeight="32" ItemWidth="170" Orientation="Horizontal">
                                <controls:Button Click="OnRichTextResetClick" Content="Load Sample Content" />
                                <controls:Button Click="OnRichTextAppendPlainClick" Content="Append Plain Text" />
                                <controls:Button Click="OnRichTextAppendHtmlClick" Content="Append HTML" />
                                <controls:Button Click="OnRichTextMarkdownClick" Content="Load Markdown" />
                                <controls:Button Click="OnRichTextInsertImageClick" Content="Insert Image" />
                                <controls:Button Click="OnRichTextReplaceSelectionClick" Content="Replace Selection" />
                                <controls:Button Click="OnRichTextExportHtmlClick" Content="Export HTML" />
                                <controls:Button Click="OnRichTextExportMarkdownClick" Content="Export Markdown" />
                                <controls:Button Click="OnRichTextSaveLoadStreamClick" Content="Save/Load Stream Sample" />
                                <controls:Button Click="OnRichTextToggleDisplayModeClick" Content="Toggle Display Mode" />
                            </WrapPanel>
                        </controls:StackPanel>

                        <controls:TextBlock
                            Name="RichTextStatusTextBlock"
                            MaxWidth="760"
                            FontSize="12"
                            Opacity="0.7"
                            Text="Status: representative content loaded; right-click the editor for the Context menu."
                            TextWrapping="Wrap" />
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  PasswordBox  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="PasswordBox" />
                    <controls:TextBlock Opacity="0.7" Text="Password boxes hide the entered characters for security." />
                    <controls:StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Standard PasswordBox:" />
                            <controls:PasswordBox PlaceholderText="Enter password..." />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  NumberBox  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="NumberBox" />
                    <controls:TextBlock Opacity="0.7" Text="Number boxes allow numeric input with increment/decrement buttons." />
                    <controls:StackPanel
                        MaxWidth="300"
                        HorizontalAlignment="Left"
                        Spacing="12">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Standard NumberBox:" />
                            <controls:NumberBox Value="42" />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  NumberPad  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="NumberPad" />
                    <controls:TextBlock Opacity="0.7" Text="NumberPad provides a touch-friendly numeric keypad." />
                    <controls:NumberPad HorizontalAlignment="Left" />
                </controls:StackPanel>
            </controls:Card>

            <!--  Slider  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="Slider" />
                    <controls:TextBlock Opacity="0.7" Text="Sliders allow selection of a value from a range." />
                    <controls:StackPanel
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Spacing="16">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Basic Slider:" />
                            <controls:Slider Maximum="100" Value="50" />
                        </controls:StackPanel>
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="Slider with Ticks:" />
                            <controls:Slider
                                Maximum="100"
                                TickFrequency="25"
                                TickPlacement="BottomRight"
                                Value="75" />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  SquareSlider  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="SquareSlider" />
                    <controls:TextBlock Opacity="0.7" Text="SquareSlider allows 2D value selection in a square area." />
                    <controls:SquareSlider
                        Width="200"
                        Height="200"
                        HorizontalAlignment="Left" />
                </controls:StackPanel>
            </controls:Card>

            <!--  RatingControl  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="RatingControl" />
                    <controls:TextBlock Opacity="0.7" Text="RatingControl allows users to provide a star rating." />
                    <controls:StackPanel Spacing="8">
                        <controls:RatingControl Value="3" />
                        <controls:RatingControl Value="4.5" />
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>

            <!--  ThumbRate  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="ThumbRate" />
                    <controls:TextBlock Opacity="0.7" Text="ThumbRate provides thumbs up/down feedback." />
                    <controls:ThumbRate HorizontalAlignment="Left" />
                </controls:StackPanel>
            </controls:Card>

            <!--  ColorPicker  -->
            <controls:Card>
                <controls:StackPanel Spacing="12">
                    <controls:TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="ColorPicker" />
                    <controls:TextBlock Opacity="0.7" Text="Color pickers allow selection of colors using RGB sliders." />
                    <controls:StackPanel Spacing="16">
                        <controls:StackPanel>
                            <controls:TextBlock
                                Margin="0,0,0,4"
                                FontSize="12"
                                Text="ColorPicker (with Alpha):" />
                            <controls:ColorPicker HorizontalAlignment="Left" IsAlphaEnabled="True" />
                        </controls:StackPanel>
                    </controls:StackPanel>
                </controls:StackPanel>
            </controls:Card>
        </controls:StackPanel>
    </ScrollViewer>
</UserControl>
