<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrissCross.Avalonia.UI.Controls;assembly=CrissCross.Avalonia.UI">
    
    <!-- CrissCross Anchor Style -->
    <Style Selector="controls|Anchor">
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="controls|Anchor:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorLight1}" />
    </Style>
    
    <Style Selector="controls|Anchor:pressed">
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorDark1}" />
    </Style>
    
    <Style Selector="controls|Anchor:disabled">
        <Setter Property="Opacity" Value="0.5" />
    </Style>
    
</Styles>
