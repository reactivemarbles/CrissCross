<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrissCross.Avalonia.UI.Controls;assembly=CrissCross.Avalonia.UI">

    <Style Selector="controls|ThemeSwitcher">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="System"
                                Content="System" />
                        <Button Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Light"
                                Content="Light" />
                        <Button Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Dark"
                                Content="Dark" />
                        <Button Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="HighContrast"
                                Content="High contrast" />
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0"
                               Opacity="0.72"
                               Text="{Binding CurrentState.DisplayText, RelativeSource={RelativeSource TemplatedParent}}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
