<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CrissCross.Avalonia.UI.Controls;assembly=CrissCross.Avalonia.UI">
    
    <!-- CrissCross AlarmBanner Style -->
    <Style Selector="controls|AlarmBanner">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="RootBorder"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="4"
                        BorderThickness="1"
                        IsVisible="{TemplateBinding IsActive}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <!-- Severity icon -->
                        <TextBlock Name="SeverityIcon"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                        <!-- Message -->
                        <TextBlock Grid.Column="1"
                                   Text="{TemplateBinding Message}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                        <!-- Acknowledge button -->
                        <Button Name="PART_AcknowledgeButton"
                                Grid.Column="2"
                                Content="{TemplateBinding AcknowledgeText}"
                                Command="{TemplateBinding AcknowledgeCommand}"
                                IsVisible="{TemplateBinding IsAcknowledgeVisible}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Padding="12,6" />
                        <!-- Close button -->
                        <Button Name="PART_CloseButton"
                                Grid.Column="3"
                                Command="{TemplateBinding CloseCommand}"
                                IsVisible="{TemplateBinding IsClosable}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="12" />
                        </Button>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <!-- Severity-based styling -->
    <Style Selector="controls|AlarmBanner[Severity=Error] /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource InfoBarErrorSeverityBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarErrorSeverityBackground}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Warning] /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource InfoBarCautionSeverityBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarCautionSeverityBackground}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Success] /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource InfoBarSuccessSeverityBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarSuccessSeverityBackground}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Informational] /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource InfoBarInformationalSeverityBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarInformationalSeverityBackground}" />
    </Style>
    
    <!-- Severity icons -->
    <Style Selector="controls|AlarmBanner[Severity=Error] /template/ TextBlock#SeverityIcon">
        <Setter Property="Text" Value="&#xEA39;" />
        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCritical}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Warning] /template/ TextBlock#SeverityIcon">
        <Setter Property="Text" Value="&#xE7BA;" />
        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCaution}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Success] /template/ TextBlock#SeverityIcon">
        <Setter Property="Text" Value="&#xE73E;" />
        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccess}" />
    </Style>
    
    <Style Selector="controls|AlarmBanner[Severity=Informational] /template/ TextBlock#SeverityIcon">
        <Setter Property="Text" Value="&#xE946;" />
        <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}" />
    </Style>
    
</Styles>
