<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(CrissCrossWinTargetFrameworks)</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <!-- Build quality / reproducibility -->
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)'=='true' Or '$(BUILD_BUILDID)'!=''">true</ContinuousIntegrationBuild>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RepositoryUrl>https://github.com/reactivemarbles/CrissCross</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/reactivemarbles/CrissCross</PackageProjectUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EnablePackageValidation>true</EnablePackageValidation>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <NoWarn>$(NoWarn);CA1812</NoWarn>
  </PropertyGroup>

  <!-- Release specific optimizations -->
  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <Optimize>true</Optimize>
  </PropertyGroup>

  <!-- .NET Framework specific references -->
  <ItemGroup Condition="$(TargetFramework.StartsWith('net4'))">
    <Reference Include="System.Net.Http" />
    <PackageReference Include="Polyfill">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.Buffers" />
    <PackageReference Include="System.Memory" />
  </ItemGroup>

  <ItemGroup>
    <!-- Core dependencies -->
    <PackageReference Include="CP.Extensions.Hosting.ReactiveUI.Wpf" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" />
    <PackageReference Include="CP.Xaml.Converters" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" />
    <PackageReference Include="ReactiveList" />
    <!-- Source generators / analyzers isolated from consumers -->
    <PackageReference Include="ReactiveUI.SourceGenerators" PrivateAssets="all" />
  </ItemGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\CrissCross.WPF\CrissCross.WPF.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Page Update="Controls\ModernWindow\ModernWindow.xaml">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Page>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Controls\Alarms\" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Controls\AppBarButton\Assets\svg\*.svg" />
    <None Remove="Controls\ColorSelector\icon.png" />
    <None Remove="Controls\Gauges\RedCross.png" />
    <Page Remove="Controls\AppBarButton\Assets\AppBar\*.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Images\*.png" />
    <Resource Include="Resources\Fonts\*.ttf" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Controls\AppBarButton\Assets\AppBar\*.xaml">
      <LogicalName>CrissCross.WPF.UI.Controls.AppBarButton.Assets.AppBar.%(Filename)%(Extension)</LogicalName>
      <WithCulture>false</WithCulture>
    </EmbeddedResource>
    <EmbeddedResource Include="Controls\AppBarButton\Assets\svg\*.svg">
      <LogicalName>CrissCross.WPF.UI.Controls.AppBarButton.Assets.svg.%(Filename)%(Extension)</LogicalName>
      <WithCulture>false</WithCulture>
    </EmbeddedResource>
    <EmbeddedResource Include="Controls\**\*.png" />
    <EmbeddedResource Include="Controls\**\*.bmp" />
  </ItemGroup>

</Project>
