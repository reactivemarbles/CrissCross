<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:CrissCross.WPF.UI.Converters"
    xmlns:ui="clr-namespace:CrissCross.WPF.UI.Controls">

    <converters:ToLowerConverter x:Key="AppBarButtonToLowerConverter" />
    <converters:ToUpperConverter x:Key="AppBarButtonToUpperConverter" />

    <Style TargetType="{x:Type ui:AppBarButton}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
        <Setter Property="ForegroundGlyphColor" Value="{DynamicResource ButtonForeground}" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ui:AppBarButton}">
                    <Grid
                        x:Name="LayoutRoot"
                        MaxWidth="100"
                        Margin="{TemplateBinding Padding}"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                        <StackPanel>
                            <Grid Width="{TemplateBinding ElipseDiameter}" Height="{TemplateBinding ElipseDiameter}">
                                <Ellipse
                                    x:Name="IconBorder"
                                    VerticalAlignment="Stretch"
                                    Stroke="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                    StrokeThickness="1" />
                                <Path
                                    x:Name="IconPath"
                                    Width="{TemplateBinding IconWidth}"
                                    Height="{TemplateBinding IconHeight}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="{TemplateBinding IconData}"
                                    Fill="{TemplateBinding Foreground}"
                                    Stretch="Uniform" />
                                <TextBlock
                                    x:Name="BackgroundGlyph"
                                    Margin="0,-2,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="{TemplateBinding BackgroundGlyphFontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding BackgroundGlyph}" />
                                <TextBlock
                                    x:Name="ForegroundGlyph"
                                    Margin="0,-2,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="{TemplateBinding ForegroundGlyphFontSize}"
                                    Foreground="{TemplateBinding ForegroundGlyphColor}"
                                    Text="{TemplateBinding ForegroundGlyph}" />
                            </Grid>
                            <TextBlock
                                MaxWidth="88"
                                MaxHeight="32"
                                Margin="0,0,2,0"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                DataContext="{TemplateBinding Content}"
                                FontSize="12"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{Binding Converter={StaticResource AppBarButtonToLowerConverter}}"
                                TextAlignment="Center"
                                TextTrimming="WordEllipsis"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundPointerOver}" />
                            <Setter TargetName="IconBorder" Property="Stroke" Value="{DynamicResource ButtonForegroundPointerOver}" />
                            <Setter TargetName="ForegroundGlyph" Property="Foreground" Value="{DynamicResource ButtonForegroundPointerOver}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundPressed}" />
                            <Setter TargetName="IconBorder" Property="Fill" Value="{DynamicResource SystemAccentColorBrush}" />
                            <Setter TargetName="IconBorder" Property="Stroke" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            <Setter TargetName="BackgroundGlyph" Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            <Setter TargetName="ForegroundGlyph" Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
                            <Setter TargetName="IconBorder" Property="Stroke" Value="{DynamicResource ControlStrongStrokeColorDisabledBrush}" />
                            <Setter TargetName="ForegroundGlyph" Property="Foreground" Value="{DynamicResource ButtonForegroundDisabled}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="IconBorder" Property="Stroke" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
