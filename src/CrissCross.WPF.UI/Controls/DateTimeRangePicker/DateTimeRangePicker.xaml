<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:DateTimeRangePicker}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:DateTimeRangePicker}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button
                                MinWidth="72"
                                Margin="0,0,6,6"
                                Command="{Binding ApplyPresetCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Today"
                                Content="Today" />
                            <Button
                                MinWidth="86"
                                Margin="0,0,6,6"
                                Command="{Binding ApplyPresetCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Yesterday"
                                Content="Yesterday" />
                            <Button
                                MinWidth="92"
                                Margin="0,0,6,6"
                                Command="{Binding ApplyPresetCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="LastSevenDays"
                                Content="Last 7 days" />
                            <Button
                                MinWidth="86"
                                Margin="0,0,0,6"
                                Command="{Binding ApplyPresetCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="ThisMonth"
                                Content="This month" />
                        </StackPanel>
                        <TextBlock
                            Margin="0,2,0,0"
                            Opacity="0.72"
                            Text="{Binding CurrentRange.DisplayText, RelativeSource={RelativeSource TemplatedParent}}" />
                        <TextBlock
                            Margin="0,2,0,0"
                            Opacity="0.72"
                            Text="{Binding CurrentRange.ValidationMessage, RelativeSource={RelativeSource TemplatedParent}}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
