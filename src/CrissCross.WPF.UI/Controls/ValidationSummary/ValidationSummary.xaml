<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls"
  xmlns:core="clr-namespace:CrissCross;assembly=CrissCross"
>
  <Style TargetType="{x:Type controls:ValidationSummary}">
    <Setter Property="ItemTemplate">
      <Setter.Value>
        <DataTemplate DataType="{x:Type core:ValidationMessage}">
          <Button
            Margin="0,0,0,4"
            HorizontalContentAlignment="Stretch"
            Command="{Binding NavigateToFieldCommand, RelativeSource={RelativeSource AncestorType={x:Type controls:ValidationSummary}}}"
            CommandParameter="{Binding}"
          >
            <StackPanel>
              <TextBlock FontWeight="SemiBold" Text="{Binding Severity}" />
              <TextBlock Text="{Binding DisplayText}" />
            </StackPanel>
          </Button>
        </DataTemplate>
      </Setter.Value>
    </Setter>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type controls:ValidationSummary}">
          <Border Padding="12" Background="#0FC42B1C" BorderBrush="#33C42B1C" BorderThickness="1" CornerRadius="6">
            <StackPanel>
              <TextBlock
                FontWeight="SemiBold"
                Text="{Binding SummaryState.SummaryText, RelativeSource={RelativeSource TemplatedParent}}"
              />
              <ItemsPresenter Margin="0,8,0,0" />
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
