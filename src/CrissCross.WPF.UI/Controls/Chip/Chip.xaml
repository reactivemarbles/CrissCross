<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:Chip}">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Chip}">
                    <Border
                        Padding="10,4"
                        Background="#14000000"
                        BorderBrush="#22000000"
                        BorderThickness="1"
                        CornerRadius="14">
                        <StackPanel Orientation="Horizontal">
                            <ContentPresenter
                                Margin="0,0,6,0"
                                Content="{TemplateBinding Icon}" />
                            <Button
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding SelectCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="{Binding Model, RelativeSource={RelativeSource TemplatedParent}}"
                                Content="{TemplateBinding Text}" />
                            <Button
                                MinWidth="24"
                                Margin="6,0,0,0"
                                Command="{Binding RemoveCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="{Binding Model, RelativeSource={RelativeSource TemplatedParent}}"
                                Content="×" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
