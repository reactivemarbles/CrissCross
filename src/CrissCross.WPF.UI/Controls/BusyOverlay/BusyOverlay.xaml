<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:BusyOverlay}">
        <Setter Property="Background" Value="#80000000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BusyOverlay}">
                    <Grid>
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
                        <Border
                            x:Name="Overlay"
                            Background="{TemplateBinding Background}"
                            Visibility="Collapsed">
                            <StackPanel
                                MaxWidth="420"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <controls:ProgressRing
                                    Width="44"
                                    Height="44"
                                    HorizontalAlignment="Center"
                                    IsIndeterminate="True" />
                                <TextBlock
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding Operation.Title, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=Working}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Center"
                                    Foreground="White"
                                    Opacity="0.8"
                                    Text="{Binding Operation.Message, RelativeSource={RelativeSource TemplatedParent}}"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                                <Button
                                    x:Name="CancelButton"
                                    MinWidth="96"
                                    Margin="0,16,0,0"
                                    Command="{Binding Operation.CancelCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="Cancel" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsBusy" Value="True">
                            <Setter TargetName="Overlay" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <DataTrigger Binding="{Binding Operation.IsCancellable, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                            <Setter TargetName="CancelButton" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
