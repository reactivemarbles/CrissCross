<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls"
    xmlns:core="clr-namespace:CrissCross;assembly=CrissCross">

    <Style TargetType="{x:Type controls:FilterBar}">
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type core:FilterToken}">
                    <Border
                        Margin="0,0,6,6"
                        Padding="10,4"
                        Background="#14000000"
                        CornerRadius="12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{Binding DisplayText}" />
                            <Button
                                MinWidth="24"
                                Margin="6,0,0,0"
                                Command="{Binding RemoveFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type controls:FilterBar}}}"
                                CommandParameter="{Binding}"
                                Content="×" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FilterBar}">
                    <DockPanel LastChildFill="True">
                        <Button
                            DockPanel.Dock="Right"
                            MinWidth="72"
                            Margin="8,0,0,6"
                            Command="{Binding ClearAllCommand, RelativeSource={RelativeSource TemplatedParent}}"
                            Content="Clear" />
                        <ItemsPresenter />
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
