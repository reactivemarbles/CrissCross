<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:ThemeSwitcher}">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ThemeSwitcher}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button
                                MinWidth="72"
                                Margin="0,0,6,0"
                                Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="System"
                                Content="System" />
                            <Button
                                MinWidth="72"
                                Margin="0,0,6,0"
                                Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Light"
                                Content="Light" />
                            <Button
                                MinWidth="72"
                                Margin="0,0,6,0"
                                Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="Dark"
                                Content="Dark" />
                            <Button
                                MinWidth="112"
                                Command="{Binding ApplyThemeCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                CommandParameter="HighContrast"
                                Content="High contrast" />
                        </StackPanel>
                        <TextBlock
                            Margin="0,6,0,0"
                            Opacity="0.72"
                            Text="{Binding CurrentState.DisplayText, RelativeSource={RelativeSource TemplatedParent}}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
