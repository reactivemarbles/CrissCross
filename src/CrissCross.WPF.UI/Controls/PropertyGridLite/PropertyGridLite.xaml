<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:PropertyGridLite}">
        <Setter Property="MinHeight" Value="160" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:PropertyGridLite}">
                    <Border
                        Padding="12"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8" LastChildFill="True">
                                <TextBlock
                                    DockPanel.Dock="Left"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Text="Properties" />
                                <TextBlock
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center"
                                    Opacity="0.72"
                                    Text="{Binding InspectorState.SummaryText, RelativeSource={RelativeSource TemplatedParent}}" />
                                <TextBox
                                    MinWidth="180"
                                    Text="{Binding SearchText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding InspectorState.Categories, RelativeSource={RelativeSource TemplatedParent}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                FontWeight="SemiBold"
                                                Text="{Binding Name}" />
                                            <ItemsControl ItemsSource="{Binding Descriptors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                Text="{Binding DisplayName}" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Opacity="0.86"
                                                                Text="{Binding ValueDisplayText}" />
                                                            <Button
                                                                Grid.Column="2"
                                                                Margin="8,0,0,0"
                                                                Command="{Binding ResetCommand}"
                                                                Content="Reset"
                                                                IsEnabled="{Binding CanReset}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button
                                    MinWidth="72"
                                    Margin="0,0,8,0"
                                    Command="{Binding ResetCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="Reset"
                                    IsEnabled="{Binding InspectorState.CanReset, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Button
                                    MinWidth="72"
                                    Command="{Binding CommitCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                    Content="Commit"
                                    IsEnabled="{Binding InspectorState.CanCommit, RelativeSource={RelativeSource TemplatedParent}}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
