<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:CrissCross.WPF.UI.Controls">

    <Style TargetType="{x:Type controls:CommandButton}" BasedOn="{StaticResource DefaultUiButtonStyle}">
        <Setter Property="MinHeight" Value="32" />
    </Style>

    <Style TargetType="{x:Type controls:AsyncCommandButton}" BasedOn="{StaticResource {x:Type controls:CommandButton}}">
        <Setter Property="ExecutingContent" Value="Working..." />
    </Style>

</ResourceDictionary>
