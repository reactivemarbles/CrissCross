<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\ReactiveShim.props" />

  <PropertyGroup>
    <TargetFrameworks>$(CrissCrossWinTargetFrameworks)</TargetFrameworks>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ProduceReferenceAssembly>true</ProduceReferenceAssembly>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\CrissCross.WinForms\**\*.cs"
             Exclude="..\CrissCross.WinForms\bin\**;..\CrissCross.WinForms\obj\**"
             LinkBase="CrissCross.WinForms" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ReactiveUI.WinForms.Reactive" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CrissCross.Reactive\CrissCross.Reactive.csproj" />
  </ItemGroup>
</Project>
