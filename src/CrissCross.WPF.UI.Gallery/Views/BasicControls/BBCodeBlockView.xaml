<UserControl
    x:Class="CrissCross.WPF.UI.Gallery.Views.BBCodeBlockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="https://github.com/reactivemarbles/CrissCross.ui"
    d:DesignHeight="720"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:ImageIcon
                Width="30"
                Height="30"
                VerticalAlignment="Center"
                Source="/Assets/ControlImages/RichTextBlock.png" />
            <StackPanel Grid.Column="1" Margin="10,0,20,0">
                <ui:TextBlock
                    FontSize="24"
                    FontWeight="Bold"
                    Text="BBCodeBlock" />
                <ui:TextBlock
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="bbcode.org reference syntax plus safe, documented common extensions."
                    TextWrapping="Wrap" />
            </StackPanel>
            <ui:ThemeSwitcher
                Grid.Column="2"
                Width="340"
                VerticalAlignment="Center" />
        </Grid>
        <ui:DynamicScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,0,12,18">
                <Border
                    Margin="0,0,0,10"
                    Padding="10"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <ui:TextBlock
                            FontWeight="SemiBold"
                            Text="Reactive command link result" />
                        <ui:TextBlock
                            Margin="0,3,0,0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding ViewModel.LastCommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding ViewModel.ExampleGroups, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,14">
                                <ui:TextBlock
                                    Margin="0,4,0,6"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{Binding Title}" />
                                <ItemsControl ItemsSource="{Binding Examples}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:CardExpander
                                                Margin="0,0,0,6"
                                                Header="{Binding Title}">
                                                <Grid Margin="10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <ui:TextBlock
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding Description}"
                                                        TextWrapping="Wrap" />
                                                    <ui:TextBox
                                                        Grid.Row="1"
                                                        Margin="0,8,0,8"
                                                        FontFamily="Consolas"
                                                        IsReadOnly="True"
                                                        Text="{Binding Markup, Mode=OneWay}"
                                                        TextWrapping="Wrap" />
                                                    <Border
                                                        Grid.Row="2"
                                                        MinHeight="42"
                                                        Padding="10"
                                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                        <ui:BBCodeBlock
                                                            BBCode="{Binding Markup}"
                                                            Command="{Binding ViewModel.ExampleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            OpenExternalLinks="False" />
                                                    </Border>
                                                </Grid>
                                            </ui:CardExpander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</UserControl>
